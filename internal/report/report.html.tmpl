<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>gocrawl report — {{.Seed}}</title>
<style>
  :root {
    --fg:#1f2328; --muted:#59636e; --bg:#f4f6f9; --panel:#ffffff;
    --border:#d8dee4; --error:#cf222e; --warning:#9a6700; --info:#0969da;
    --error-bg:#ffeef0; --warning-bg:#fff8e6; --info-bg:#ddf4ff;
    --shadow:0 1px 3px rgba(27,31,36,.08),0 1px 2px rgba(27,31,36,.06);
  }
  * { box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body {
    margin:0; padding:0; color:var(--fg); background:var(--bg);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
    line-height:1.5; font-size:14px;
  }
  main { max-width:90rem; margin:0 auto; padding:0 1.5rem 4rem; }
  header.hero {
    background:linear-gradient(135deg,#0d1117 0%,#1f2937 100%);
    color:#fff; padding:2rem 1.5rem; margin-bottom:1.5rem;
  }
  header.hero .inner { max-width:90rem; margin:0 auto; }
  header.hero h1 { margin:0; font-size:1.6rem; letter-spacing:-.01em; }
  header.hero .sub { margin-top:.5rem; color:#aeb7c2; font-size:.9rem; }
  header.hero .sub code { background:rgba(255,255,255,.12); padding:.1rem .45rem; border-radius:4px; color:#e6edf3; }
  .cov-banner {
    display:flex; gap:.75rem; align-items:flex-start; margin:0 0 1.5rem;
    background:var(--warning-bg); border:1px solid var(--warning);
    border-left:4px solid var(--warning); border-radius:10px; padding:.85rem 1.1rem; color:#6b4e00;
  }
  .cov-banner .ico { font-size:1.1rem; line-height:1.3; flex:none; }
  .cov-banner .body { font-size:.9rem; }
  .cov-banner strong { color:#7a4f00; }
  .cov-banner code { background:rgba(154,103,0,.14); padding:.1rem .4rem; border-radius:4px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  .tiles { display:grid; grid-template-columns:repeat(auto-fit,minmax(11rem,1fr)); gap:1rem; margin-bottom:1.75rem; }
  .tile { background:var(--panel); border:1px solid var(--border); border-radius:10px; padding:1rem 1.15rem; box-shadow:var(--shadow); }
  .tile .n { font-size:2rem; font-weight:700; font-variant-numeric:tabular-nums; line-height:1; }
  .tile .l { margin-top:.4rem; color:var(--muted); font-size:.8rem; text-transform:uppercase; letter-spacing:.05em; font-weight:600; }
  .tile.t-error { border-top:3px solid var(--error); } .tile.t-error .n { color:var(--error); }
  .tile.t-warning { border-top:3px solid var(--warning); } .tile.t-warning .n { color:var(--warning); }
  .tile.t-info { border-top:3px solid var(--info); } .tile.t-info .n { color:var(--info); }
  .tile.t-total { border-top:3px solid #6e7781; }
  h2 { margin:2rem 0 .9rem; font-size:1.2rem; letter-spacing:-.01em; }
  .cards { display:flex; flex-wrap:wrap; gap:1rem; }
  .card { flex:1 1 16rem; background:var(--panel); border:1px solid var(--border); border-radius:10px; padding:1rem 1.15rem; box-shadow:var(--shadow); }
  .card h3 { margin:0 0 .65rem; font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); }
  .card table { width:100%; border-collapse:collapse; font-size:.9rem; }
  .card td { padding:.25rem 0; border-bottom:1px solid #eef1f4; }
  .card tr:last-child td { border-bottom:0; }
  .card td:last-child { text-align:right; font-variant-numeric:tabular-nums; font-weight:600; }
  .empty { color:var(--muted); font-style:italic; }
  .toolbar {
    display:flex; flex-wrap:wrap; gap:.6rem; align-items:center;
    background:var(--bg); padding:.85rem 0; border-bottom:1px solid var(--border);
  }
  .toolbar input[type=search] {
    flex:1 1 18rem; min-width:12rem; padding:.5rem .75rem; font-size:.9rem;
    border:1px solid var(--border); border-radius:8px; background:#fff;
  }
  .toolbar select { padding:.5rem .6rem; border:1px solid var(--border); border-radius:8px; background:#fff; font-size:.9rem; }
  .msel { position:relative; }
  .msel > button {
    cursor:pointer; padding:.5rem .7rem; border:1px solid var(--border); border-radius:8px;
    background:#fff; font-size:.9rem; color:var(--fg); font-family:inherit;
  }
  .msel > button:hover { border-color:var(--muted); }
  .msel > button .caret { color:var(--muted); margin-left:.35rem; }
  .msel.has-hidden > button { border-color:var(--info); color:var(--info); font-weight:600; }
  .msel-panel {
    position:absolute; z-index:30; top:calc(100% + .25rem); left:0; min-width:16rem; max-width:24rem;
    max-height:20rem; overflow:auto; background:#fff; border:1px solid var(--border);
    border-radius:8px; box-shadow:0 6px 18px rgba(27,31,36,.16); padding:.4rem;
  }
  .msel-panel[hidden] { display:none; }
  .msel-panel .msel-acts { display:flex; gap:.5rem; padding:.25rem .35rem .45rem; border-bottom:1px solid #eef1f4; margin-bottom:.35rem; }
  .msel-panel .msel-acts button {
    cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--info);
    padding:.25rem .55rem; border-radius:6px; font-size:.78rem; font-weight:600; font-family:inherit;
  }
  .msel-panel label {
    display:flex; align-items:center; gap:.45rem; padding:.3rem .35rem; border-radius:6px;
    font-size:.84rem; cursor:pointer; user-select:none;
  }
  .msel-panel label:hover { background:#f0f6ff; }
  .msel-panel label input { margin:0; }
  .msel-panel label code { font-size:.8rem; background:#f0f3f6; padding:.05rem .35rem; border-radius:4px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  .msel-panel label .msel-n { margin-left:auto; color:var(--muted); font-variant-numeric:tabular-nums; }
  .sevfilters { display:flex; gap:.4rem; }
  .sevbtn {
    cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--muted);
    padding:.45rem .7rem; border-radius:8px; font-size:.82rem; font-weight:600; opacity:.55;
  }
  .sevbtn.active { opacity:1; }
  .sevbtn.sev-error.active { background:var(--error-bg); border-color:var(--error); color:var(--error); }
  .sevbtn.sev-warning.active { background:var(--warning-bg); border-color:var(--warning); color:var(--warning); }
  .sevbtn.sev-info.active { background:var(--info-bg); border-color:var(--info); color:var(--info); }
  .count { margin-left:auto; color:var(--muted); font-size:.85rem; font-variant-numeric:tabular-nums; }
  .tablewrap { background:var(--panel); border:1px solid var(--border); border-top:0; border-radius:0 0 10px 10px; box-shadow:var(--shadow); overflow:hidden; }
  table.issues { width:100%; border-collapse:collapse; font-size:.88rem; }
  table.issues thead th {
    position:sticky; top:0; z-index:20; text-align:left; padding:.6rem .8rem;
    background:#eaeef2; color:var(--muted); font-size:.74rem; text-transform:uppercase;
    letter-spacing:.04em; font-weight:700; border-bottom:1px solid var(--border); white-space:nowrap;
  }
  table.issues thead th.sortable { cursor:pointer; user-select:none; }
  table.issues thead th.sortable:hover { color:var(--fg); }
  table.issues thead th[data-dir=asc]::after { content:" \25B2"; font-size:.7em; }
  table.issues thead th[data-dir=desc]::after { content:" \25BC"; font-size:.7em; }
  table.issues tbody td { padding:.55rem .8rem; border-bottom:1px solid #eef1f4; vertical-align:top; }
  table.issues tbody tr:nth-child(even) { background:#fafbfc; }
  table.issues tbody tr:hover { background:#f0f6ff; }
  table.issues tbody tr { border-left:3px solid transparent; }
  table.issues td.url { word-break:break-all; max-width:24rem; }
  table.issues td.url a { color:var(--info); text-decoration:none; }
  table.issues td.url a:hover { text-decoration:underline; }
  table.issues td code { font-size:.82rem; background:#f0f3f6; padding:.1rem .4rem; border-radius:4px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  .badge { display:inline-block; padding:.15rem .55rem; border-radius:999px; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; }
  .badge.sev-error { background:var(--error-bg); color:var(--error); }
  .badge.sev-warning { background:var(--warning-bg); color:var(--warning); }
  .badge.sev-info { background:var(--info-bg); color:var(--info); }
  details { margin-top:.4rem; }
  details summary { cursor:pointer; color:var(--info); font-size:.8rem; font-weight:600; width:fit-content; border-radius:4px; }
  details summary:focus { outline:none; }
  details summary:focus-visible { outline:2px solid var(--info); outline-offset:2px; }
  details pre { background:#f6f8fa; border:1px solid var(--border); border-radius:6px; padding:.6rem .8rem; margin:.4rem 0 0; font-size:.8rem; overflow-x:auto; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  details.explain dl { margin:.4rem 0 0; padding:.55rem .8rem; background:#f6f8fa; border:1px solid var(--border); border-left:3px solid var(--info); border-radius:6px; font-size:.85rem; }
  details.explain dt { font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; font-size:.68rem; margin-top:.55rem; }
  details.explain dt:first-child { margin-top:0; }
  details.explain dd { margin:.15rem 0 0; color:var(--fg); }
  .toolbar label.hidetog { display:flex; align-items:center; gap:.35rem; font-size:.82rem; color:var(--muted); font-weight:600; cursor:pointer; user-select:none; }
  .toolbar .bulk { display:flex; align-items:center; gap:.4rem; padding-left:.5rem; margin-left:.1rem; border-left:1px solid var(--border); }
  .toolbar .bulk button { cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--fg); padding:.45rem .6rem; border-radius:8px; font-size:.8rem; font-weight:600; font-family:inherit; }
  .toolbar .bulk button:hover:not(:disabled) { border-color:var(--muted); }
  .toolbar .bulk button:disabled { opacity:.4; cursor:default; }
  .toolbar .bulk .seln { color:var(--info); font-size:.8rem; font-weight:600; font-variant-numeric:tabular-nums; min-width:0; }
  table.issues td.review { white-space:nowrap; }
  table.issues td.review label { display:flex; align-items:center; gap:.35rem; font-size:.78rem; color:var(--muted); font-weight:600; cursor:pointer; user-select:none; margin-bottom:.2rem; }
  table.issues td.review label.sel { color:var(--info); border-bottom:1px solid #eef1f4; padding-bottom:.25rem; margin-bottom:.3rem; }
  table.issues td.review label input { margin:0; }
  table.issues td.review textarea { margin-top:.35rem; width:13rem; max-width:100%; font:inherit; font-size:.8rem; padding:.35rem .5rem; border:1px solid var(--border); border-radius:6px; resize:vertical; background:#fff; }
  table.issues tbody tr.reviewed { opacity:.5; }
  table.issues tbody tr.reviewed:hover { opacity:1; }
  table.issues tbody tr.reviewed td.url a { text-decoration:line-through; }
  /* tabs */
  .tabs { display:flex; gap:.25rem; margin:0 0 1.5rem; border-bottom:1px solid var(--border); }
  .tabs .tab { appearance:none; border:0; background:none; font:inherit; font-weight:600; color:var(--muted); padding:.6rem .9rem; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-1px; }
  .tabs .tab:hover { color:var(--fg); }
  .tabs .tab.active { color:var(--info); border-bottom-color:var(--info); }
  .tabpanel[hidden] { display:none; }
  /* site-map: node-link (org-chart) diagram */
  #tab-sitemap .sm-meta { color:var(--muted); font-size:.9rem; margin-bottom:.75rem; }
  #tab-sitemap .sm-meta code { background:#eef1f4; padding:.1rem .45rem; border-radius:4px; }
  #tab-sitemap .sm-controls { display:flex; gap:.5rem; align-items:center; flex-wrap:wrap; margin-bottom:.75rem; }
  #tab-sitemap .sm-controls button { cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--fg); padding:.4rem .7rem; border-radius:8px; font-size:.82rem; font-weight:600; font-family:inherit; }
  #tab-sitemap .sm-controls button:hover { border-color:var(--muted); }
  #tab-sitemap .sm-controls .sm-hint { color:var(--muted); font-size:.82rem; }
  #tab-sitemap .sm-chartwrap { overflow:auto; background:var(--panel); border:1px solid var(--border); border-radius:10px; box-shadow:var(--shadow); padding:1.5rem 1rem 2rem; }
  /* nested flex lists + elbow connectors = a top-down org chart */
  #tab-sitemap ul.sm-chart, #tab-sitemap ul.sm-chart ul { display:flex; justify-content:center; list-style:none; margin:0; padding:0; padding-top:1.4rem; position:relative; }
  #tab-sitemap ul.sm-chart { padding-top:0; min-width:max-content; }
  #tab-sitemap .sm-chart li { display:flex; flex-direction:column; align-items:center; position:relative; padding:1.4rem .55rem 0; }
  #tab-sitemap .sm-chart li::before, #tab-sitemap .sm-chart li::after { content:""; position:absolute; top:0; right:50%; width:50%; height:1.4rem; border-top:2px solid var(--border); }
  #tab-sitemap .sm-chart li::after { right:auto; left:50%; border-left:2px solid var(--border); }
  #tab-sitemap .sm-chart li:only-child { padding-top:0; }
  #tab-sitemap .sm-chart li:only-child::before, #tab-sitemap .sm-chart li:only-child::after { display:none; }
  #tab-sitemap .sm-chart li:first-child::before, #tab-sitemap .sm-chart li:last-child::after { border:0; }
  #tab-sitemap .sm-chart li:last-child::before { border-right:2px solid var(--border); border-radius:0 6px 0 0; }
  #tab-sitemap .sm-chart li:first-child::after { border-radius:6px 0 0 0; }
  #tab-sitemap .sm-chart ul::before { content:""; position:absolute; top:0; left:50%; width:0; height:1.4rem; border-left:2px solid var(--border); }
  #tab-sitemap li.sm-collapsed > ul { display:none; }
  /* node card, colored by page health */
  #tab-sitemap .sm-box { position:relative; min-width:7rem; max-width:13rem; background:#fff; border:1px solid var(--border); border-top:3px solid var(--border); border-radius:8px; padding:.45rem .6rem; box-shadow:var(--shadow); text-align:left; }
  #tab-sitemap .sm-box.sm-h-error { border-top-color:var(--error); }
  #tab-sitemap .sm-box.sm-h-warning { border-top-color:var(--warning); }
  #tab-sitemap .sm-box.sm-h-info { border-top-color:var(--info); }
  #tab-sitemap .sm-box.sm-h-ok { border-top-color:#1a7f37; }
  #tab-sitemap .sm-box.sm-h-none { border-top-color:var(--border); background:#fafbfc; }
  #tab-sitemap .sm-box.sm-haspop { cursor:pointer; }
  #tab-sitemap .sm-box.sm-haspop:hover { border-color:var(--info); }
  #tab-sitemap .sm-box.sm-sel { box-shadow:0 0 0 2px var(--info); }
  #tab-sitemap .sm-box-head { display:flex; align-items:center; gap:.35rem; }
  #tab-sitemap .sm-box-toggle { cursor:pointer; flex:none; width:1.15rem; height:1.15rem; line-height:1; text-align:center; border:1px solid var(--border); border-radius:5px; background:#fff; color:var(--muted); font-weight:700; font-size:.85rem; padding:0; font-family:inherit; }
  #tab-sitemap .sm-box-toggle:hover { color:var(--fg); border-color:var(--muted); }
  #tab-sitemap .sm-box-label { font-weight:700; color:var(--info); text-decoration:none; word-break:break-word; font-size:.85rem; }
  #tab-sitemap .sm-box-label:hover { text-decoration:underline; }
  #tab-sitemap .sm-box-title { color:var(--muted); font-size:.74rem; margin-top:.15rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  #tab-sitemap .sm-box-foot { display:flex; flex-wrap:wrap; align-items:center; gap:.25rem; margin-top:.35rem; }
  #tab-sitemap .sm-box-foot:empty { display:none; }
  /* status + severity pills (shared with the issues popover and site-wide list) */
  #tab-sitemap .sm-st { display:inline-block; min-width:2.2em; text-align:center; font-size:.68rem; font-weight:700; padding:1px 5px; border-radius:4px; vertical-align:middle; }
  #tab-sitemap .st-ok { background:#e3f6e8; color:#1a7f37; }
  #tab-sitemap .st-redirect { background:var(--warning-bg); color:var(--warning); }
  #tab-sitemap .st-error { background:var(--error-bg); color:var(--error); }
  #tab-sitemap .st-none { background:#eef1f4; color:var(--muted); }
  #tab-sitemap .sm-sev { display:inline-block; min-width:1.5em; text-align:center; font-size:.68rem; font-weight:700; padding:1px 5px; border-radius:10px; vertical-align:middle; }
  #tab-sitemap .sm-error { background:var(--error-bg); color:var(--error); }
  #tab-sitemap .sm-warning { background:var(--warning-bg); color:var(--warning); }
  #tab-sitemap .sm-info { background:var(--info-bg); color:var(--info); }
  #tab-sitemap .sm-roll { opacity:.75; font-weight:700; color:var(--muted); font-size:.72rem; }
  #tab-sitemap .sm-roll::before { content:"\2211"; margin-right:1px; }
  /* issues popover (opens below a node when clicked) */
  #tab-sitemap .sm-pop { position:absolute; top:calc(100% + .3rem); left:0; z-index:15; min-width:15rem; max-width:24rem; text-align:left; background:#fff; border:1px solid var(--border); border-radius:8px; box-shadow:0 6px 18px rgba(27,31,36,.16); padding:.5rem .6rem; white-space:normal; }
  #tab-sitemap .sm-pop[hidden] { display:none; }
  #tab-sitemap .sm-pop-h { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); margin-bottom:.35rem; }
  #tab-sitemap ul.sm-issuelist { list-style:none; margin:0; padding:0; }
  #tab-sitemap li.sm-issue { font-size:.8rem; margin:.25rem 0; display:flex; gap:.4rem; align-items:baseline; flex-wrap:wrap; }
  #tab-sitemap .sm-dot { width:.55em; height:.55em; border-radius:50%; flex:none; align-self:center; }
  #tab-sitemap .sm-issue.sev-error .sm-dot { background:var(--error); }
  #tab-sitemap .sm-issue.sev-warning .sm-dot { background:var(--warning); }
  #tab-sitemap .sm-issue.sev-info .sm-dot { background:var(--info); }
  #tab-sitemap li.sm-issue code { background:#f0f3f6; padding:.1rem .4rem; border-radius:4px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  #tab-sitemap .sm-an { color:var(--muted); }
  #tab-sitemap h3 { margin:1.5rem 0 .6rem; font-size:1rem; }
  #tab-sitemap h3 + ul.sm-issuelist { background:var(--panel); border:1px solid var(--border); border-radius:10px; box-shadow:var(--shadow); padding:.6rem .9rem; }
  #tab-sitemap .sm-muted { color:var(--muted); font-weight:400; font-size:.85rem; }
</style>
</head>
<body>
<header class="hero"><div class="inner">
  <h1>gocrawl report</h1>
  <div class="sub">
    Seed: <code>{{.Seed}}</code>
    · {{.PagesCrawled}} page{{if ne .PagesCrawled 1}}s{{end}} crawled
    · started {{.StartedAt}} · finished {{.FinishedAt}}
  </div>
</div></header>
{{/* Recursive site-map partials: an org-chart of node cards (rendered in the Site map tab).
     severityClass/statusClass come from the FuncMap; collapse + popover behavior is wired in JS. */}}
{{define "smbadges"}}{{if .Error}}<span class="sm-sev sm-error" title="errors">{{.Error}}</span>{{end}}{{if .Warning}}<span class="sm-sev sm-warning" title="warnings">{{.Warning}}</span>{{end}}{{if .Info}}<span class="sm-sev sm-info" title="info">{{.Info}}</span>{{end}}{{end}}
{{define "smrollup"}}{{if and .Children (gt .Subtotal.Total .Counts.Total)}}<span class="sm-roll" title="issues in this branch">{{.Subtotal.Total}}</span>{{end}}{{end}}
{{define "smissues"}}{{if .Issues}}<div class="sm-pop" hidden><div class="sm-pop-h">{{len .Issues}} issue{{if ne (len .Issues) 1}}s{{end}} on this page</div><ul class="sm-issuelist">{{range .Issues}}<li class="sm-issue {{severityClass .Severity}}"><span class="sm-dot"></span><code>{{.Code}}</code><span class="sm-an">{{.Analyzer}}</span><span class="sm-msg">{{.Message}}</span></li>{{end}}</ul></div>{{end}}{{end}}
{{define "smbox"}}<div class="sm-box {{if .URL}}{{if .Counts.Error}}sm-h-error{{else if .Counts.Warning}}sm-h-warning{{else if .Counts.Info}}sm-h-info{{else}}sm-h-ok{{end}}{{else}}sm-h-none{{end}}{{if .Issues}} sm-haspop{{end}}"><div class="sm-box-head">{{if .Children}}<button type="button" class="sm-box-toggle" title="collapse / expand subtree">&#8722;</button>{{end}}{{if .URL}}<a href="{{.URL}}" class="sm-box-label" title="{{.URL}}" target="_blank" rel="noopener">{{if .Label}}{{.Label}}{{else}}/{{end}}</a>{{else}}<span class="sm-box-label">{{.Label}}</span>{{end}}{{if .Status}}<span class="sm-st {{statusClass .Status}}">{{.Status}}</span>{{end}}</div>{{if .Title}}<div class="sm-box-title" title="{{.Title}}">{{.Title}}</div>{{end}}<div class="sm-box-foot">{{template "smbadges" .Counts}}{{template "smrollup" .}}</div>{{template "smissues" .}}</div>{{end}}
{{define "smchartnode"}}<li class="sm-li{{if .Children}} sm-haskids{{end}}">{{template "smbox" .}}{{if .Children}}<ul>{{range .Children}}{{template "smchartnode" .}}{{end}}</ul>{{end}}</li>{{end}}
<main>
  {{if .Coverage}}{{if not .Coverage.Complete}}
  <div class="cov-banner" role="alert">
    <span class="ico">&#9888;&#65039;</span>
    <div class="body">
      <strong>Partial coverage — this crawl did not reach the whole site.</strong>
      {{.Coverage.DiscoveredNotCrawled}} in-scope URL{{if ne .Coverage.DiscoveredNotCrawled 1}}s were{{else}} was{{end}} discovered but not crawled{{if .Coverage.PageLimitReached}}, because the page limit (<code>--max-pages {{.Coverage.MaxPages}}</code>) was reached{{end}}{{if .Coverage.DepthLimitReached}}{{if .Coverage.PageLimitReached}} and{{else}}, because{{end}} the depth limit (<code>--depth {{.Coverage.MaxDepth}}</code>) was reached{{end}}.
      Page-level findings — <strong>broken links especially</strong> — may be incomplete. Re-crawl with a higher limit (or <code>0</code> for unlimited) for full coverage.
    </div>
  </div>
  {{end}}{{end}}
  <nav class="tabs">
    <button type="button" class="tab active" data-tab="report">Issues &amp; summary</button>
    {{if .SiteMap}}<button type="button" class="tab" data-tab="sitemap">Site map</button>{{end}}
  </nav>

  <section class="tabpanel" id="tab-report">
  <div class="tiles" id="tiles"></div>

  <h2>Summary</h2>
  <div class="cards">
    <div class="card">
      <h3>By severity</h3>
      {{if .Summary.BySeverity}}
      <table>
        {{range $k, $v := .Summary.BySeverity}}
        <tr><td><span class="badge {{severityClass $k}}">{{$k}}</span></td><td>{{$v}}</td></tr>
        {{end}}
      </table>
      {{else}}<div class="empty">No issues.</div>{{end}}
    </div>
    <div class="card">
      <h3>By analyzer</h3>
      {{if .Summary.ByAnalyzer}}
      <table>
        {{range $k, $v := .Summary.ByAnalyzer}}
        <tr><td>{{$k}}</td><td>{{$v}}</td></tr>
        {{end}}
      </table>
      {{else}}<div class="empty">No analyzers reported.</div>{{end}}
    </div>
    <div class="card">
      <h3>Pages by status</h3>
      {{if .Summary.ByStatus}}
      <table>
        {{range $k, $v := .Summary.ByStatus}}
        <tr><td>{{$k}}</td><td>{{$v}}</td></tr>
        {{end}}
      </table>
      {{else}}<div class="empty">No pages crawled.</div>{{end}}
    </div>
  </div>

  <h2>Issues ({{len .Issues}})</h2>
  {{if .Issues}}
  <div class="toolbar" id="toolbar"></div>
  <div class="tablewrap">
  <table class="issues" id="issuesTable">
    <thead>
      <tr><th>Severity</th><th>Analyzer</th><th>Code</th><th>URL</th><th>Message</th><th class="nosort">Review</th></tr>
    </thead>
    <tbody>
      {{range .Issues}}
      <tr>
        <td><span class="badge {{severityClass (printf "%s" .Severity)}}">{{.Severity}}</span></td>
        <td>{{.Analyzer}}</td>
        <td><code>{{.Code}}</code></td>
        <td class="url"><a href="{{.URL}}" target="_blank" rel="noopener">{{.URL}}</a></td>
        <td>
          {{.Message}}
          {{$ex := explain (printf "%s" .Code)}}
          {{with $ex}}
          <details class="explain">
            <summary>what this means &amp; how to fix</summary>
            <dl>
              <dt>What it is</dt><dd>{{.What}}</dd>
              <dt>Impact</dt><dd>{{.Impact}}</dd>
              <dt>How to fix</dt><dd>{{.Fix}}</dd>
            </dl>
          </details>
          {{end}}
          {{if .Data}}
          <details><summary>data</summary><pre>{{dataJSON .Data}}</pre></details>
          {{end}}
        </td>
        <td class="review">
          <label class="sel"><input type="checkbox" class="ck-sel">Select</label>
          <label><input type="checkbox" class="ck-resolved">Resolved</label>
          <label><input type="checkbox" class="ck-nonissue">Non-issue</label>
          <textarea class="note" rows="2" placeholder="Add a comment…"></textarea>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <p class="empty">No issues found.</p>
  {{end}}
  </section>

  {{if .SiteMap}}
  <section class="tabpanel" id="tab-sitemap" hidden>
    <div class="sm-meta">
      <code>{{.SiteMap.Host}}</code> · {{len .SiteMap.Entries}} indexable page{{if ne (len .SiteMap.Entries) 1}}s{{end}}
      {{if not .SiteMap.Totals.Empty}}· {{template "smbadges" .SiteMap.Totals}} total{{end}}
    </div>
    <div class="sm-controls">
      <button type="button" class="sm-expand-all">Expand all</button>
      <button type="button" class="sm-collapse-all">Collapse all</button>
      <span class="sm-hint">Click a node to see its issues · click a label to open the page · &#8722;/+ collapses a branch</span>
    </div>
    <div class="sm-chartwrap">
      <ul class="sm-chart">{{template "smchartnode" .SiteMap.Root}}</ul>
    </div>
    {{if .SiteMap.SiteWide}}
    <h3>Site-wide issues <span class="sm-muted">({{len .SiteMap.SiteWide}}, not tied to a single page)</span></h3>
    <ul class="sm-issuelist">{{range .SiteMap.SiteWide}}<li class="sm-issue {{severityClass .Severity}}"><span class="sm-dot"></span><code>{{.Code}}</code><span class="sm-an">{{.Analyzer}}</span><span class="sm-msg">{{.Message}}</span></li>{{end}}</ul>
    {{end}}
  </section>
  {{end}}
</main>
<script>
(function(){
  var tabs=document.querySelectorAll('.tabs .tab');
  if(tabs.length<2){return;}
  function show(name){
    Array.prototype.forEach.call(document.querySelectorAll('.tabpanel'),function(p){p.hidden=(p.id!=='tab-'+name);});
    Array.prototype.forEach.call(tabs,function(t){t.classList.toggle('active',t.getAttribute('data-tab')===name);});
  }
  Array.prototype.forEach.call(tabs,function(t){t.addEventListener('click',function(){show(t.getAttribute('data-tab'));});});
})();
(function(){
  var table=document.getElementById('issuesTable');
  if(!table){return;}
  var tbody=table.tBodies[0];
  var rows=Array.prototype.slice.call(tbody.rows);
  var rank={error:0,warning:1,info:2};
  var counts={error:0,warning:0,info:0};
  rows.forEach(function(r){
    var b=r.querySelector('.badge');
    r._sev=b?b.textContent.trim().toLowerCase():'';
    r._an=r.cells[1]?r.cells[1].textContent.trim():'';
    r._code=r.cells[2]?r.cells[2].textContent.trim():'';
    r._t=r.textContent.toLowerCase();
    if(counts[r._sev]!=null){counts[r._sev]++;}
    r.style.borderLeftColor=({error:'#cf222e',warning:'#9a6700',info:'#0969da'})[r._sev]||'transparent';
  });
  function tile(cls,n,l){return '<div class="tile '+cls+'"><div class="n">'+Number(n).toLocaleString()+'</div><div class="l">'+l+'</div></div>';}
  var tiles=document.getElementById('tiles');
  if(tiles){
    tiles.innerHTML=
      tile('t-total',rows.length,'Total issues')+
      tile('t-error',counts.error,'Errors')+
      tile('t-warning',counts.warning,'Warnings')+
      tile('t-info',counts.info,'Info');
  }
  rows.sort(function(a,b){return (rank[a._sev]-rank[b._sev])||0;});
  var f0=document.createDocumentFragment(); rows.forEach(function(r){f0.appendChild(r);}); tbody.appendChild(f0);
  var ans={}; rows.forEach(function(r){if(r._an){ans[r._an]=1;}});
  var anlist=Object.keys(ans).sort();
  var codeCounts={}; rows.forEach(function(r){if(r._code){codeCounts[r._code]=(codeCounts[r._code]||0)+1;}});
  var codelist=Object.keys(codeCounts).sort();
  function esc(s){return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
  var tb=document.getElementById('toolbar');
  tb.innerHTML='<input type="search" id="q" placeholder="Search URL, message, code…">'+
    '<div class="sevfilters">'+
      '<button data-sev="error" class="sevbtn sev-error active">Errors</button>'+
      '<button data-sev="warning" class="sevbtn sev-warning active">Warnings</button>'+
      '<button data-sev="info" class="sevbtn sev-info active">Info</button>'+
    '</div>'+
    '<select id="anSel"><option value="">All analyzers</option>'+
      anlist.map(function(a){return '<option value="'+esc(a)+'">'+esc(a)+'</option>';}).join('')+
    '</select>'+
    '<div class="msel" id="codeMsel">'+
      '<button type="button" id="codeMselBtn" aria-expanded="false">Codes<span class="caret">▾</span></button>'+
      '<div class="msel-panel" id="codeMselPanel" hidden>'+
        '<div class="msel-acts"><button type="button" data-all="1">Select all</button><button type="button" data-all="0">Hide all</button></div>'+
        codelist.map(function(c){return '<label><input type="checkbox" class="ck-code" value="'+esc(c)+'" checked><code>'+esc(c)+'</code><span class="msel-n">'+codeCounts[c]+'</span></label>';}).join('')+
      '</div>'+
    '</div>'+
    '<label class="hidetog"><input type="checkbox" id="hideResolved">Hide resolved</label>'+
    '<label class="hidetog"><input type="checkbox" id="hideNon">Hide non-issues</label>'+
    '<span class="bulk">'+
      '<label class="hidetog"><input type="checkbox" id="selAll">Select shown</label>'+
      '<button type="button" id="bulkNon" disabled title="Mark every selected (and currently shown) issue as a non-issue">&#8594; Non-issue</button>'+
      '<button type="button" id="bulkRes" disabled title="Mark every selected (and currently shown) issue as resolved">&#8594; Resolved</button>'+
      '<button type="button" id="bulkClr" disabled title="Clear the resolved / non-issue flags on selected issues">Clear</button>'+
      '<span class="seln" id="selCount"></span>'+
    '</span>'+
    '<button type="button" id="saveBtn" class="sevbtn active" title="Download this report with your review state baked in">Save to file</button>'+
    '<span class="count" id="count"></span>';
  var q=document.getElementById('q'),sel=document.getElementById('anSel'),ce=document.getElementById('count');
  var hideResolved=document.getElementById('hideResolved'),hideNon=document.getElementById('hideNon');
  var selAll=document.getElementById('selAll'),bulkNon=document.getElementById('bulkNon'),
      bulkRes=document.getElementById('bulkRes'),bulkClr=document.getElementById('bulkClr'),
      selCount=document.getElementById('selCount');
  var on={error:true,warning:true,info:true};
  var codeOn={}; codelist.forEach(function(c){codeOn[c]=true;});
  function apply(){
    var term=q.value.trim().toLowerCase(),an=sel.value,shown=0;
    for(var i=0;i<rows.length;i++){var r=rows[i],ok=on[r._sev]!==false;
      if(ok&&an&&r._an!==an){ok=false;}
      if(ok&&r._code&&codeOn[r._code]===false){ok=false;}
      if(ok&&term&&r._t.indexOf(term)===-1){ok=false;}
      if(ok&&hideResolved.checked&&r._resolved&&r._resolved.checked){ok=false;}
      if(ok&&hideNon.checked&&r._nonissue&&r._nonissue.checked){ok=false;}
      r.style.display=ok?'':'none'; if(ok){shown++;}}
    ce.textContent='Showing '+shown.toLocaleString()+' of '+rows.length.toLocaleString()+' issues';
    updateSel();
  }
  // Bulk review acts only on rows that are both selected and currently shown, so a hidden
  // (filtered-out) issue is never silently marked. "Select shown" ticks exactly the visible set.
  function updateSel(){
    var vis=0,selc=0;
    rows.forEach(function(r){
      if(r.style.display==='none'){return;}
      vis++; if(r._sel&&r._sel.checked){selc++;}
    });
    if(selAll){selAll.checked=(vis>0&&selc===vis);selAll.indeterminate=(selc>0&&selc<vis);}
    if(selCount){selCount.textContent=selc?(selc.toLocaleString()+' selected'):'';}
    var none=selc===0;
    if(bulkNon){bulkNon.disabled=none;} if(bulkRes){bulkRes.disabled=none;} if(bulkClr){bulkClr.disabled=none;}
  }
  function bulk(kind){
    var n=0;
    rows.forEach(function(r){
      if(r.style.display==='none'||!r._sel||!r._sel.checked){return;}
      if(kind==='non'){if(r._nonissue){r._nonissue.checked=true;}}
      else if(kind==='res'){if(r._resolved){r._resolved.checked=true;}}
      else{if(r._resolved){r._resolved.checked=false;}if(r._nonissue){r._nonissue.checked=false;}}
      r._sel.checked=false; refresh(r); n++;
    });
    if(n){markDirty();}
    apply(); // re-filters (e.g. "Hide non-issues" now drops them) and refreshes selection state
  }
  // Review state: checkboxes + comment live in the DOM and are saved back into the file
  // via the "Save to file" button, so a shared report carries its own state — no cookies,
  // no localStorage, nothing to be cleared by the browser.
  var dirty=false,saveBtn=document.getElementById('saveBtn');
  function markDirty(){if(!dirty){dirty=true;saveBtn.textContent='Save to file *';}}
  function refresh(r){
    r.classList.toggle('reviewed',(r._resolved&&r._resolved.checked)||(r._nonissue&&r._nonissue.checked));
  }
  rows.forEach(function(r){
    r._resolved=r.querySelector('.ck-resolved');
    r._nonissue=r.querySelector('.ck-nonissue');
    r._sel=r.querySelector('.ck-sel');
    var note=r.querySelector('.note');
    refresh(r);
    function onToggle(){refresh(r);markDirty();apply();}
    if(r._resolved){r._resolved.addEventListener('change',onToggle);}
    if(r._nonissue){r._nonissue.addEventListener('change',onToggle);}
    if(r._sel){r._sel.addEventListener('change',updateSel);}
    if(note){note.addEventListener('input',markDirty);}
  });
  if(selAll){selAll.addEventListener('change',function(){
    var v=selAll.checked;
    rows.forEach(function(r){if(r.style.display!=='none'&&r._sel){r._sel.checked=v;}});
    updateSel();
  });}
  if(bulkNon){bulkNon.addEventListener('click',function(){bulk('non');});}
  if(bulkRes){bulkRes.addEventListener('click',function(){bulk('res');});}
  if(bulkClr){bulkClr.addEventListener('click',function(){bulk('clr');});}
  function save(){
    // Reflect live form state into HTML attributes/content so it serializes into the file.
    // Only the review flags persist — the transient bulk-selection checkboxes are excluded.
    Array.prototype.forEach.call(document.querySelectorAll('table.issues .ck-resolved,table.issues .ck-nonissue'),function(cb){
      if(cb.checked){cb.setAttribute('checked','checked');}else{cb.removeAttribute('checked');}
    });
    Array.prototype.forEach.call(document.querySelectorAll('table.issues textarea.note'),function(ta){ta.textContent=ta.value;});
    var html='<!doctype html>\n'+document.documentElement.outerHTML;
    var a=document.createElement('a');
    a.href=URL.createObjectURL(new Blob([html],{type:'text/html'}));
    a.download=(document.title||'gocrawl-report')+'.html';
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
    dirty=false;saveBtn.textContent='Save to file';
  }
  saveBtn.addEventListener('click',save);
  window.addEventListener('beforeunload',function(e){if(dirty){e.preventDefault();e.returnValue='';}});
  hideResolved.addEventListener('change',apply);
  hideNon.addEventListener('change',apply);
  var t; q.addEventListener('input',function(){clearTimeout(t);t=setTimeout(apply,150);});
  sel.addEventListener('change',apply);
  Array.prototype.forEach.call(tb.querySelectorAll('.sevbtn'),function(btn){
    btn.addEventListener('click',function(){var s=btn.getAttribute('data-sev');on[s]=!on[s];btn.classList.toggle('active');apply();});
  });
  // Codes multi-select: uncheck a code to hide its issues (e.g. meta-noindex on a staging site).
  var codeMsel=document.getElementById('codeMsel'),codeBtn=document.getElementById('codeMselBtn'),
      codePanel=document.getElementById('codeMselPanel'),codeBoxes=codePanel?codePanel.querySelectorAll('.ck-code'):[];
  function syncCodeBtn(){
    var hidden=codelist.filter(function(c){return codeOn[c]===false;}).length;
    codeMsel.classList.toggle('has-hidden',hidden>0);
    codeBtn.firstChild.nodeValue=hidden>0?('Codes ('+hidden+' hidden)'):'Codes';
  }
  if(codeBtn&&codePanel){
    codeBtn.addEventListener('click',function(e){
      e.stopPropagation();
      var open=codePanel.hidden; codePanel.hidden=!open; codeBtn.setAttribute('aria-expanded',String(open));
    });
    codePanel.addEventListener('click',function(e){e.stopPropagation();});
    document.addEventListener('click',function(){codePanel.hidden=true;codeBtn.setAttribute('aria-expanded','false');});
    Array.prototype.forEach.call(codeBoxes,function(cb){
      cb.addEventListener('change',function(){codeOn[cb.value]=cb.checked;syncCodeBtn();apply();});
    });
    Array.prototype.forEach.call(codePanel.querySelectorAll('.msel-acts button'),function(b){
      b.addEventListener('click',function(){
        var v=b.getAttribute('data-all')==='1';
        Array.prototype.forEach.call(codeBoxes,function(cb){cb.checked=v;codeOn[cb.value]=v;});
        syncCodeBtn();apply();
      });
    });
  }
  var ths=table.tHead.rows[0].cells,st={c:-1,d:1};
  Array.prototype.forEach.call(ths,function(th,idx){
    if(th.classList.contains('nosort')){return;}
    th.classList.add('sortable');
    th.addEventListener('click',function(){
      var d=(st.c===idx)?-st.d:1; st={c:idx,d:d};
      rows.sort(function(a,b){var x,y;
        if(idx===0){x=rank[a._sev];y=rank[b._sev];}
        else{x=a.cells[idx].textContent.trim().toLowerCase();y=b.cells[idx].textContent.trim().toLowerCase();}
        return x<y?-d:x>y?d:0;});
      var fr=document.createDocumentFragment(); rows.forEach(function(r){fr.appendChild(r);}); tbody.appendChild(fr);
      Array.prototype.forEach.call(ths,function(h){h.removeAttribute('data-dir');});
      th.setAttribute('data-dir',d>0?'asc':'desc');
    });
  });
  apply();
})();
(function(){
  // Site-map org chart: collapse/expand branches and pop up a node's issues on click.
  var smp=document.getElementById('tab-sitemap'); if(!smp){return;}
  var chart=smp.querySelector('.sm-chart'); if(!chart){return;}
  var lis=Array.prototype.slice.call(smp.querySelectorAll('li.sm-li'));
  var MINUS='−';
  function syncToggle(li){
    var t=li.querySelector('.sm-box-toggle');
    if(t){t.textContent=li.classList.contains('sm-collapsed')?'+':MINUS;}
  }
  function depth(li){
    var d=0,p=li.parentElement;
    while(p&&p!==chart){if(p.tagName==='LI'){d++;}p=p.parentElement;}
    return d;
  }
  // Default view: keep the chart compact by collapsing branches deeper than two levels.
  lis.forEach(function(li){
    if(li.classList.contains('sm-haskids')&&depth(li)>=2){li.classList.add('sm-collapsed');}
    syncToggle(li);
  });
  Array.prototype.forEach.call(smp.querySelectorAll('.sm-box-toggle'),function(tog){
    tog.addEventListener('click',function(e){
      e.preventDefault();e.stopPropagation();
      var li=tog.closest('li.sm-li'); if(!li){return;}
      li.classList.toggle('sm-collapsed'); syncToggle(li);
    });
  });
  function closePops(except){
    Array.prototype.forEach.call(smp.querySelectorAll('.sm-pop'),function(p){
      if(p!==except){p.hidden=true;p.parentElement.classList.remove('sm-sel');}
    });
  }
  Array.prototype.forEach.call(smp.querySelectorAll('.sm-box.sm-haspop'),function(box){
    box.addEventListener('click',function(e){
      if(e.target.closest('a')||e.target.closest('.sm-box-toggle')){return;}
      var pop=box.querySelector('.sm-pop'); if(!pop){return;}
      e.stopPropagation();
      var willOpen=pop.hidden; closePops(willOpen?pop:null);
      pop.hidden=!willOpen; box.classList.toggle('sm-sel',willOpen);
    });
  });
  Array.prototype.forEach.call(smp.querySelectorAll('.sm-pop'),function(p){
    p.addEventListener('click',function(e){e.stopPropagation();}); // clicks inside stay open (links still navigate)
  });
  document.addEventListener('click',function(){closePops(null);});
  var ea=smp.querySelector('.sm-expand-all'),ca=smp.querySelector('.sm-collapse-all');
  if(ea){ea.addEventListener('click',function(){lis.forEach(function(li){li.classList.remove('sm-collapsed');syncToggle(li);});});}
  if(ca){ca.addEventListener('click',function(){lis.forEach(function(li){
    if(li.classList.contains('sm-haskids')&&depth(li)>=1){li.classList.add('sm-collapsed');}syncToggle(li);
  });});}
})();
</script>
</body>
</html>
